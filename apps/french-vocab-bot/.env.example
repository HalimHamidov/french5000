BOT_TOKEN=your_token_here
ADMIN_CHAT_ID=your_chat_id_here

# Database path (relative to french-vocab-bot/)
DB_PATH=db/app.db

# Data file path (relative to repository root)
DATA_PATH=data/processed/french_frequency_dictionary.json

# Default timezone (e.g. Europe/Paris, UTC, America/New_York)
TIMEZONE=UTC

# Default words per day (12-15)
WORDS_PER_DAY=12

# Scheduled times (24h format HH:MM)
MORNING_REVIEW_TIME=08:00
AFTERNOON_LESSON_TIME=14:00
EVENING_REMINDER_TIME=20:00
WEEKLY_SUMMARY_DAY=sunday
